  <script>
  // ─────────────────────────────────────────────
  // CONFIGURACIÓN
  // ─────────────────────────────────────────────
  // ► REEMPLAZAR con tu endpoint de Formspree
  var FORMSPREE_URL = 'https://formspree.io/f/xlgzbnpd';

  // ─────────────────────────────────────────────
  // ESTADO GLOBAL
  // ─────────────────────────────────────────────
  var currentStep = 1;
  var files = { frente: null, dorso: null };
  var tratamientoVal = '';

  // ─────────────────────────────────────────────
  // STEPPER
  // ─────────────────────────────────────────────
  function updateStepper(step){
    for(var i=1;i<=4;i++){
      var el = document.getElementById('s'+i);
      el.classList.remove('active','done');
      if(i < step) el.classList.add('done');
      else if(i === step) el.classList.add('active');
    }
    // Conectores
    for(var j=1;j<=3;j++){
      var conn = document.getElementById('conn-'+j+'-'+(j+1));
      conn.classList.toggle('done', j < step);
    }
  }

  // ─────────────────────────────────────────────
  // NAVEGACIÓN ENTRE PASOS
  // ─────────────────────────────────────────────
  function goTo(target){
    // Si avanzamos, validar paso actual
    if(target > currentStep){
      if(!validateStep(currentStep)) return;
    }
    // Si llegamos al paso 4, poblar resumen
    if(target === 4) populateSummary();

    document.getElementById('panel-'+currentStep).classList.remove('visible');
    currentStep = target;
    document.getElementById('panel-'+currentStep).classList.add('visible');
    updateStepper(currentStep);
    window.scrollTo({top:0, behavior:'smooth'});
  }

  // ─────────────────────────────────────────────
  // VALIDACIONES
  // ─────────────────────────────────────────────
  function validateStep(step){
    if(step===1) return validateStep1();
    if(step===2) return validateStep2();
    if(step===3) return validateStep3();
    return true;
  }

  function setError(fieldId, show){
    var el = document.getElementById(fieldId);
    if(show) el.classList.add('error');
    else el.classList.remove('error');
  }

  function validateStep1(){
    var ok = true;
    var nombre = document.getElementById('nombre').value.trim();
    var telefono = document.getElementById('telefono').value.trim();
    var email = document.getElementById('email').value.trim();
    var civil = document.getElementById('estado-civil').value;

    setError('f-nombre', !nombre);
    setError('f-telefono', !telefono);
    var emailOk = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
    setError('f-email', !emailOk);
    setError('f-estado-civil', !civil);

    if(!nombre||!telefono||!emailOk||!civil) ok=false;
    return ok;
  }

  function validateStep2(){
    var ok = true;
    var errF = document.getElementById('err-frente');
    var errD = document.getElementById('err-dorso');
    if(!files.frente){ errF.classList.add('show'); ok=false; } else { errF.classList.remove('show'); }
    if(!files.dorso){ errD.classList.add('show'); ok=false; } else { errD.classList.remove('show'); }
    return ok;
  }

  function validateStep3(){
    var ok = true;
    var sexo = document.getElementById('sexo').value;
    var altura = document.getElementById('altura').value.trim();
    var peso = document.getElementById('peso').value.trim();
    var ocup = document.getElementById('ocupacion').value.trim();
    var errTrat = document.getElementById('err-tratamiento');

    setError('f-sexo', !sexo);
    setError('f-altura', !altura);
    setError('f-peso', !peso);
    setError('f-ocupacion', !ocup);

    if(!tratamientoVal){ errTrat.classList.add('show'); ok=false; } else { errTrat.classList.remove('show'); }

    // Si SI, validar campo ampliar
    if(tratamientoVal==='SI'){
      var amp = document.getElementById('ampliar').value.trim();
      setError('f-ampliar', !amp);
      if(!amp) ok=false;
    }

    if(!sexo||!altura||!peso||!ocup) ok=false;
    return ok;
  }

  // ─────────────────────────────────────────────
  // RADIO BUTTONS (tratamiento)
  // ─────────────────────────────────────────────
  function selectRadio(group, val){
    tratamientoVal = val;
    document.getElementById('trat-si').checked = (val==='SI');
    document.getElementById('trat-no').checked = (val==='NO');
    document.getElementById('rb-si').classList.toggle('selected', val==='SI');
    document.getElementById('rb-no').classList.toggle('selected', val==='NO');
    document.getElementById('err-tratamiento').classList.remove('show');
    // Mostrar / ocultar campo ampliar
    var fAmp = document.getElementById('f-ampliar');
    fAmp.style.display = (val==='SI') ? 'flex' : 'none';
    if(val==='NO'){
      document.getElementById('ampliar').value='';
      setError('f-ampliar',false);
    }
  }

  // ─────────────────────────────────────────────
  // CARGA DE ARCHIVOS
  // ─────────────────────────────────────────────
  // ─────────────────────────────────────────────
  // CARGA DE ARCHIVOS — click y change
  // ─────────────────────────────────────────────
  ['frente','dorso'].forEach(function(side){
    var area  = document.getElementById('area-'+side);
    var input = document.getElementById('dni-'+side);

    // Tap / click en el área dispara el input oculto
    area.addEventListener('click', function(e){
      e.stopPropagation();
      input.click();
    });

    // Cuando el usuario selecciona archivo
    input.addEventListener('change', function(){
      if(this.files && this.files[0]) handleFile(side, this.files[0]);
    });

    // Drag & Drop
    area.addEventListener('dragover',  function(e){ e.preventDefault(); area.classList.add('dragover'); });
    area.addEventListener('dragleave', function()  { area.classList.remove('dragover'); });
    area.addEventListener('drop',      function(e){
      e.preventDefault();
      area.classList.remove('dragover');
      var f = e.dataTransfer.files[0];
      if(f) handleFile(side, f);
    });
  });

  function handleFile(side, file){
    files[side] = file;
    document.getElementById('prev-'+side+'-name').textContent = file.name;
    document.getElementById('prev-'+side).classList.add('show');
    document.getElementById('area-'+side).style.display = 'none';
    document.getElementById('err-'+side).classList.remove('show');
  }

  function removeFile(side){
    files[side] = null;
    document.getElementById('dni-'+side).value = '';
    document.getElementById('prev-'+side).classList.remove('show');
    document.getElementById('area-'+side).style.display = '';
  }

  // ─────────────────────────────────────────────
  // RESUMEN PASO 4
  // ─────────────────────────────────────────────
  function populateSummary(){
    document.getElementById('sum-nombre').textContent = document.getElementById('nombre').value.trim();
    document.getElementById('sum-telefono').textContent = document.getElementById('telefono').value.trim();
    document.getElementById('sum-email').textContent = document.getElementById('email').value.trim();
    document.getElementById('sum-estado-civil').textContent = document.getElementById('estado-civil').value;
    document.getElementById('sum-dni-frente').textContent = files.frente ? '✅ ' + files.frente.name : (files._frente_name ? '✅ ' + files._frente_name : '—');
    document.getElementById('sum-dni-dorso').textContent  = files.dorso  ? '✅ ' + files.dorso.name  : (files._dorso_name  ? '✅ ' + files._dorso_name  : '—');
    document.getElementById('sum-sexo').textContent = document.getElementById('sexo').value;
    document.getElementById('sum-altura').textContent = document.getElementById('altura').value + ' cm';
    document.getElementById('sum-peso').textContent = document.getElementById('peso').value + ' kg';
    document.getElementById('sum-ocupacion').textContent = document.getElementById('ocupacion').value.trim();
    document.getElementById('sum-tratamiento').textContent = tratamientoVal;
    if(tratamientoVal==='SI'){
      document.getElementById('sum-row-ampliar').style.display='flex';
      document.getElementById('sum-ampliar').textContent = document.getElementById('ampliar').value.trim();
    } else {
      document.getElementById('sum-row-ampliar').style.display='none';
    }
  }

  // ─────────────────────────────────────────────
  // GENERADOR DE REFERENCIA
  // ─────────────────────────────────────────────
  function generarReferencia(){
    var year = new Date().getFullYear();
    var num = String(Math.floor(Math.random()*999999)+1).padStart(6,'0');
    return 'VIDA-'+year+'-'+num;
  }

  // ─────────────────────────────────────────────
  // ENVÍO A FORMSPREE
  // ─────────────────────────────────────────────
  function enviarSolicitud(){
    // Validar checkboxes
    var chkDatos = document.getElementById('chk-datos').checked;
    var chkVer   = document.getElementById('chk-veracidad').checked;
    var errDatos = document.getElementById('err-chk-datos');
    var errVer   = document.getElementById('err-chk-veracidad');
    var ok = true;

    if(!chkDatos){ errDatos.classList.add('show'); ok=false; } else { errDatos.classList.remove('show'); }
    if(!chkVer){ errVer.classList.add('show'); ok=false; } else { errVer.classList.remove('show'); }
    if(!ok) return;

    var referencia = generarReferencia();
    var ahora = new Date().toLocaleString('es-AR');
    var btn = document.getElementById('btn-enviar');
    btn.disabled = true;
    btn.textContent = 'Enviando...';

    // ── Armar FormData para Formspree ──
    var fd = new FormData();
    fd.append('_subject', 'Nueva Solicitud Preliminar de Seguro de Vida — ' + referencia);

    // Datos personales
    fd.append('Nombre completo',        document.getElementById('nombre').value.trim());
    fd.append('Teléfono',               document.getElementById('telefono').value.trim());
    fd.append('Email',                  document.getElementById('email').value.trim());
    fd.append('Estado civil',           document.getElementById('estado-civil').value);

    // Salud
    fd.append('Sexo',                   document.getElementById('sexo').value);
    fd.append('Altura (cm)',            document.getElementById('altura').value);
    fd.append('Peso (kg)',              document.getElementById('peso').value);
    fd.append('Ocupación / profesión',  document.getElementById('ocupacion').value.trim());
    fd.append('Tratamiento médico',     tratamientoVal);
    if(tratamientoVal==='SI'){
      fd.append('Detalle de tratamiento', document.getElementById('ampliar').value.trim());
    }

    // Metadata
    fd.append('Fecha y hora de envío',  ahora);
    fd.append('Referencia de solicitud', referencia);

    // Archivos DNI
    if(files.frente) fd.append('DNI Frente', files.frente, files.frente.name);
    if(files.dorso)  fd.append('DNI Dorso',  files.dorso,  files.dorso.name);

    // ─────────────────────────────────────────
    // ► REEMPLAZAR la URL con tu Formspree ID
    // ► Ejemplo: 'https://formspree.io/f/abcdefgh'
    // ─────────────────────────────────────────
    fetch(FORMSPREE_URL, {
      method: 'POST',
      body: fd,
      headers: { 'Accept': 'application/json' }
    })
    .then(function(res){
      if(res.ok){
        // Éxito
        document.getElementById('panel-4').classList.remove('visible');
        document.getElementById('aviso-previo').style.display='none';
        document.getElementById('success-panel').style.display='block';
        document.getElementById('ref-display').textContent = referencia;
        updateStepper(5); // Marca todos como done
        window.scrollTo({top:0, behavior:'smooth'});
      } else {
        throw new Error('Error en el envío');
      }
    })
    .catch(function(){
      document.getElementById('send-error').style.display='block';
      btn.disabled = false;
      btn.textContent = '📤 ENVIAR SOLICITUD';
    });
  }

  // Stepper: cuando éxito marcar todos done
  var origUpdate = updateStepper;
  updateStepper = function(step){
    if(step===5){
      for(var i=1;i<=4;i++){
        var el=document.getElementById('s'+i);
        el.classList.remove('active');
        el.classList.add('done');
      }
      for(var j=1;j<=3;j++){
        document.getElementById('conn-'+j+'-'+(j+1)).classList.add('done');
      }
      return;
    }
    origUpdate(step);
  };

  // ─────────────────────────────────────────────
  // GUARDAR Y RESTAURAR ESTADO (para política de privacidad)
  // ─────────────────────────────────────────────
  function saveState(){
    var state = {
      step: currentStep,
      nombre:       document.getElementById('nombre').value,
      telefono:     document.getElementById('telefono').value,
      email:        document.getElementById('email').value,
      estado_civil: document.getElementById('estado-civil').value,
      sexo:         document.getElementById('sexo').value,
      altura:       document.getElementById('altura').value,
      peso:         document.getElementById('peso').value,
      ocupacion:    document.getElementById('ocupacion').value,
      tratamiento:  tratamientoVal,
      ampliar:      document.getElementById('ampliar').value,
      dni_frente:   files.frente ? files.frente.name : '',
      dni_dorso:    files.dorso  ? files.dorso.name  : ''
    };
    sessionStorage.setItem('solicitud_state', JSON.stringify(state));
  }

  function restoreState(){
    var raw = sessionStorage.getItem('solicitud_state');
    if(!raw) return;
    var s = JSON.parse(raw);
    sessionStorage.removeItem('solicitud_state');

    // Restaurar campos
    document.getElementById('nombre').value       = s.nombre       || '';
    document.getElementById('telefono').value     = s.telefono     || '';
    document.getElementById('email').value        = s.email        || '';
    document.getElementById('estado-civil').value = s.estado_civil || '';
    document.getElementById('sexo').value         = s.sexo         || '';
    document.getElementById('altura').value       = s.altura       || '';
    document.getElementById('peso').value         = s.peso         || '';
    document.getElementById('ocupacion').value    = s.ocupacion    || '';

    if(s.tratamiento){
      selectRadio('tratamiento', s.tratamiento);
    }
    if(s.ampliar){
      document.getElementById('ampliar').value = s.ampliar;
    }

    // Guardar nombres de DNI para mostrar en resumen
    // (los File objects no se pueden serializar, mostramos el nombre guardado)
    if(s.dni_frente){
      document.getElementById('prev-frente-name').textContent = s.dni_frente;
      document.getElementById('prev-frente').classList.add('show');
      document.getElementById('area-frente').style.display = 'none';
      // Marcamos como "nombre conocido" para el resumen
      files._frente_name = s.dni_frente;
    }
    if(s.dni_dorso){
      document.getElementById('prev-dorso-name').textContent = s.dni_dorso;
      document.getElementById('prev-dorso').classList.add('show');
      document.getElementById('area-dorso').style.display = 'none';
      files._dorso_name = s.dni_dorso;
    }

    // Ir al paso guardado (sin validar)
    if(s.step && s.step > 1){
      document.getElementById('panel-'+currentStep).classList.remove('visible');
      currentStep = s.step;
      document.getElementById('panel-'+currentStep).classList.add('visible');
      updateStepper(currentStep);
      // Si vuelve al paso 4, repoblar el resumen
      if(currentStep === 4) populateSummary();
    }
  }

  // Ejecutar al cargar
  window.addEventListener('load', restoreState);

  </script>

